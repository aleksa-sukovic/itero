#!/bin/bash

ITERO_PATH="${ITERO_PATH:-$HOME/.local/share/itero}"

usage() {
    echo "Usage: itero-theme-watch"
    echo ""
    echo "Watch GNOME accent-color changes and reapply the active Itero theme."
    echo ""
    echo "Options:"
    echo "  --help, -h    Show this help message"
}

case "${1:-}" in
    --help|-h)
        usage
        exit 0
        ;;
    "") ;;
    *)
        usage
        exit 1
        ;;
esac

export ITERO_THEME_WATCH=1

gsettings monitor org.gnome.desktop.interface accent-color | while read -r _key value; do
    "$ITERO_PATH/bin/itero-theme"
done
