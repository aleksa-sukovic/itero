#!/bin/bash

ITERO_PATH="${ITERO_PATH:-$HOME/.local/share/itero}"
THEMES_DIR="$ITERO_PATH/themes"
CURRENT_LINK="$THEMES_DIR/current"

source "$ITERO_PATH/lib/helpers.sh"

# Load environment variables
if [[ -f "$ITERO_PATH/.env" ]]; then
    set -a
    source "$ITERO_PATH/.env"
    set +a
fi

list_themes() {
    find -L "$THEMES_DIR" -mindepth 1 -maxdepth 1 -type d ! -name current \
        -exec basename {} \; 2>/dev/null | sort
}

current_theme() {
    if [ -L "$CURRENT_LINK" ]; then
        basename "$(readlink "$CURRENT_LINK")"
    else
        echo "none"
    fi
}

current_accent() {
    map_accent_to_palette "$(get_accent_color)"
}

update_pi() {
    local theme="$1"
    local theme_file="$THEMES_DIR/$theme/pi.txt"
    local settings_file="$HOME/.pi/agent/settings.json"

    [[ -f "$theme_file" && -f "$settings_file" ]] || return 0

    local pi_theme="$(sed -n '1p' "$theme_file")"

    sed -i -E "s/(\"theme\"[[:space:]]*:[[:space:]]*\")[^\"]*(\")/\1${pi_theme}\2/" "$settings_file"
}

update_vscode() {
    local theme="$1"
    local theme_file="$THEMES_DIR/$theme/vscode.txt"
    local config_roots=("$HOME/.config" "$HOME/Library/Application Support")

    [[ -f "$theme_file" ]] || return 0

    local vscode_theme="$(sed -n '1p' "$theme_file")"
    local vscode_icon_theme="$(sed -n '2p' "$theme_file")"

    while IFS= read -r -d '' settings_file; do
        sed -i -E "s/(\"workbench\.colorTheme\"[[:space:]]*:[[:space:]]*\")[^\"]*(\")/\1${vscode_theme}\2/" "$settings_file"
        sed -i -E "s/(\"workbench\.iconTheme\"[[:space:]]*:[[:space:]]*\")[^\"]*(\")/\1${vscode_icon_theme}\2/" "$settings_file"
    done < <(find "${config_roots[@]}" \( -path "*/User/settings.json" -o -path "*/User/profiles/*/settings.json" \) -print0 2>/dev/null)
}

update_yazi() {
    local theme="$1"
    local theme_file="$THEMES_DIR/$theme/yazi.toml"

    [[ -f "$theme_file" ]] || return 0

    mkdir -p "$HOME/.config/yazi"
    cp "$theme_file" "$HOME/.config/yazi/theme.toml"
}

update_wezterm() {
    touch "$HOME/.config/wezterm/wezterm.lua" 2>/dev/null || true
}

update_tmux() {
    if command_exists tmux && tmux list-sessions &>/dev/null; then
        for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null); do
            tmux source-file "$HOME/.tmux.conf" -t "$session" 2>/dev/null || true
        done
    fi
}

update_btop() {
    local theme="$1"
    local theme_file="$THEMES_DIR/$theme/btop.theme"

    [[ -f "$theme_file" ]] || return 0

    mkdir -p "$HOME/.config/btop/themes"
    ln -nsf "$theme_file" "$HOME/.config/btop/themes/current.theme"
}

update_gnome() {
    local theme="$1"
    local accent_name="$2"
    local cursor_theme="$3"

    if is_linux && command_exists gsettings; then
        gsettings set org.gnome.desktop.interface cursor-theme "default"
        gsettings set org.gnome.desktop.interface cursor-theme "$cursor_theme"
        gsettings set org.gnome.desktop.interface cursor-size 24
    fi

    if is_linux && command_exists dconf; then
        local accent_hex="$(resolve_accent_hex "$THEMES_DIR/$theme/palette.toml" "$accent_name")"
        local accent_rgb="$(hex_to_rgb "$accent_hex")"
        dconf write /org/gnome/shell/extensions/itero-wm/hint-color-rgba "'rgba(${accent_rgb}, 1)'"
    fi
}

set_theme() {
    local theme="$1"
    local accent_name="$2"

    if [[ ! -d "$THEMES_DIR/$theme" ]]; then
        echo "Theme '$theme' not found" >&2
        exit 1
    fi

    if [[ -z "$accent_name" ]]; then
        accent_name="$(map_accent_to_palette "$(get_accent_color)")"
    fi

    # Sync system accent when explicitly set
    if [[ -n "$2" ]]; then
        set_system_accent_color "$accent_name"
    fi

    local flavor="$(get_flavor "$theme")"
    local cursor_theme="catppuccin-${flavor}-${accent_name}"

    # Link the chosen theme as 'current'
    ln -nsf "$theme" "$CURRENT_LINK"

    export accent_name cursor_theme

    # Compile theme and config templates from the canonical palette
    compile_theme_templates "$THEMES_DIR/$theme" "$accent_name" "$ITERO_PATH/config" || exit 1

    # Update system & applications
    update_vscode "$theme"
    update_pi "$theme"
    update_yazi "$theme"
    update_wezterm
    update_tmux
    update_btop "$theme"
    update_gnome "$theme" "$accent_name" "$cursor_theme"

    echo "Theme: $theme (accent: $accent_name)"
}

# Parse arguments
theme=""
accent=""
action=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --list|-l)          action="list-themes" ;;
        --current|-c)       action="current-theme" ;;
        --current-accent)   action="current-accent" ;;
        --accent)
            shift
            accent="$1"
            if [[ -z "$accent" ]]; then
                echo "Missing accent color name" >&2
                exit 1
            fi
            ;;
        -*)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
        *)
            theme="$1"
            ;;
    esac
    shift
done

case "$action" in
    list-themes)    list_themes ;;
    current-theme)  current_theme ;;
    current-accent) current_accent ;;
    *)
        set_theme "${theme:-$(current_theme)}" "$accent"
        ;;
esac
