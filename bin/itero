#!/bin/bash

export ITERO_PATH="$(cd "$(dirname "$0")/.." && pwd)"
export ITERO_CONFIG="$ITERO_PATH/config"
export ITERO_INSTALL="$ITERO_PATH/install"
export ITERO_STATE="$HOME/.local/state/itero"

regular_packages=(
    "common"
    "nvidia"
    "bluetooth"
    "wezterm"
    "kitty"
    "starship"
    "fonts"
    "shell"
    "mise"
    "nvim"
    "tmux"
    "yazi"
    "lazygit"
    "lazydocker"
    "snapshots"
    "syncthing"
    "rclone"
    "apps"
    "bruno"
    "gitkraken"
    "vscode"
    "copilot"
    "pi"
    "fastfetch"
    "btop"
    "vicinae"
    "theme"
    "gnome"
    "gdm"
)

optional_packages=(
    "docker"
)

usage() {
    echo "Usage: itero [--update]"
    echo ""
    echo "Install and configure Itero components."
    echo ""
    echo "Options:"
    echo "  --update              Upgrade packages where supported"
    echo "  --help, -h            Show this help message"
    echo ""
    echo "Environment:"
    echo "  ITC=<components>      Install only comma-separated components"
    echo "  Regular packages:"
    printf "    %s\n" "${regular_packages[@]}"
    echo "  Optional packages install only when selected explicitly"
    echo "  Optional packages:"
    printf "    %s\n" "${optional_packages[@]}"
}

for arg in "$@"; do
    case "$arg" in
        --help|-h)
            usage
            exit 0
            ;;
        --update) export ITERO_UPDATE=true ;;
    esac
done

source "$ITERO_PATH/lib/helpers.sh"

if [ -z "${ITERO_GIT_PULLED:-}" ]; then
    if git -C "$ITERO_PATH" pull --ff-only --quiet; then
        exec env ITERO_GIT_PULLED=true "$ITERO_PATH/bin/itero" "$@"
    else
        log_warn "Failed to update Itero from git, continuing with the current checkout"
    fi
fi

# Check for .env file and setup environment variables
if [ ! -f "$ITERO_PATH/.env" ]; then
    if [ ! -f "$ITERO_PATH/.env.example" ]; then
        log_warn ".env.example not found. Cannot proceed."
        exit 1
    fi

    cp "$ITERO_PATH/.env.example" "$ITERO_PATH/.env"

    log_warn "Created .env file from .env.example"
    log_info "Please edit $ITERO_PATH/.env and fill in your machine-specific values"
    log_info "Then re-run: itero"

    exit 0
fi

# Load environment variables from .env
set -a
source "$ITERO_PATH/.env"
set +a

if should_update; then
    log_info "Running itero in update mode"
fi

log_info "Installing itero from $ITERO_PATH"

# Request sudo access upfront for any scripts that need it
sudo -v
if is_linux; then
    sudo install -Dm644 "$ITERO_PATH/lib/helpers.sh" "/usr/local/lib/itero/helpers.sh"
fi

# Set the current theme, if not set already
if [ -L "$ITERO_PATH/themes/current" ]; then
    current="$(basename "$(readlink "$ITERO_PATH/themes/current")")"
else
    current="catppuccin-mocha"
    ln -nsf "$current" "$ITERO_PATH/themes/current"
fi

# Resolve accent color from theme palette
accent_name="$(map_accent_to_palette "$(get_accent_color)")"

# Compile theme and config templates from the canonical palette
compile_theme_templates "$ITERO_PATH/themes/$current" "$accent_name" "$ITERO_CONFIG"

cursor_theme="$(get_cursor_theme "$ITERO_PATH/themes/$current")"
export accent_name cursor_theme

# Handle migrations
if [ ! -d "$ITERO_STATE" ]; then
    mkdir -p "$ITERO_STATE"
    "$ITERO_PATH/bin/itero-migrate" --mark-all
else
    "$ITERO_PATH/bin/itero-migrate" --run
fi

# Run regular install scripts
for package in "${regular_packages[@]}"; do
    run_install "$ITERO_INSTALL/$package.sh"
done

# Run optional install scripts
for package in "${optional_packages[@]}"; do
    run_optional_install "$ITERO_INSTALL/$package.sh"
done

log_ok "Done!"
print_install_summary
