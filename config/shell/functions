#!/bin/bash

# Navigates to the source code directory.
src() {
    cd /work/source/
}

# Platform helpers.
is_linux() {
    [ "$(uname -s)" = "Linux" ]
}

is_macos() {
    [ "$(uname -s)" = "Darwin" ]
}

# Prints local IP address.
ip-local() {
    myIP="$(ip route get 1.1.1.1 | awk '{print $7; exit}')"
    echo "Local IP: $myIP"
}

# Prints public IP address
ip-public() {
    myIP="$(dig +short myip.opendns.com @resolver1.opendns.com)"
    echo "Public IP: $myIP"
}

# Lazygit with optional path argument.
lzg() {
    lazygit -p "${1:-.}"
}

# Yazi file manager wrapper.
# Allows changing the cwd when exiting.
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    command yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
}

# Pick a command from shell history with fzf.
itero-history-fzf() {
    fc -lnr 1 | fzf --scheme=history --query="$LBUFFER"
}

# ZLE widget for replacing the current buffer from fzf history search.
itero-history-fzf-widget() {
    local selected
    selected=$(itero-history-fzf) || return
    LBUFFER="$selected"
    CURSOR=${#LBUFFER}
    zle redisplay
}
