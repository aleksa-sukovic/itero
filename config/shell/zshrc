export EDITOR=nvim
export ITERO_PATH="$HOME/.local/share/itero"
export GDRIVE_HOME="$HOME/Drive"

export EMOJI_FONT="JetBrainsMono Nerd Font" # or Twemoji; for Vicinae launcher

# Homebrew
if [ -x "/opt/homebrew/bin/brew" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x "/usr/local/bin/brew" ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# Path modifications
export PATH="$HOME/.local/share/itero/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Source machine-specific variables if they exist
if [ -f "$HOME/.zshrc.local" ]; then
    source "$HOME/.zshrc.local"
fi

# Source universal shell functions
if [ -f "$HOME/.functions" ]; then
    source "$HOME/.functions"
fi

# Source machine-specific functions if they exist
if [ -f "$HOME/.functions.local" ]; then
    source "$HOME/.functions.local"
fi

# Aliases
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

alias sudo="sudo "

alias l="ls -l"
alias la="ls -la"
alias lsd='ls -l | grep "^d"'
alias rm='rm -i'

alias fs="du -sh"

alias dcont="docker container"
alias dcomp="docker compose"

alias lzd="lazydocker"

alias v="nvim"

alias tlrc="tldr"

# Tmux
alias t="tmux attach -t main || tmux new -s main"
alias ts="tmux new -A -s"
alias ta="tmux attach -t"
alias tl="tmux list-sessions"
alias tk="tmux kill-server"

# ZSH setup
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

setopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

# Vi keybindings
bindkey -v

# Shell completion, history search, and syntax highlighting.
if is_macos; then
    zsh_site_functions="$HOMEBREW_PREFIX/share/zsh/site-functions"
    zsh_syntax_highlighting="$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
elif is_linux; then
    zsh_site_functions="/usr/share/zsh/site-functions"
    zsh_syntax_highlighting="/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

if [ -n "${zsh_site_functions:-}" ] && [ -d "$zsh_site_functions" ]; then
    fpath=("$zsh_site_functions" $fpath)
fi

autoload -Uz compinit
compinit

zle -N itero-history-fzf-widget
bindkey '^R' itero-history-fzf-widget

# Shell setup
eval "$(starship init zsh)"
eval "$(zoxide init zsh --cmd cd)"
eval "$(mise activate zsh)"

if [ -n "${zsh_syntax_highlighting:-}" ] && [ -f "$zsh_syntax_highlighting" ]; then
    source "$zsh_syntax_highlighting"
fi
